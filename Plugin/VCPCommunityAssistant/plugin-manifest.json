{
  "manifestVersion": "1.0.0",
  "name": "VCPCommunityAssistant",
  "displayName": "VCP社区小助手",
  "version": "1.1.0",
  "description": "VCP 社区的守护进程。基于社区状态看板定时唤醒 Agent，并处理提案超时治理。",
  "author": "VCP Team",
  "pluginType": "static",
  "entryPoint": {
    "type": "nodejs",
    "command": "node vcp-community-assistant.js"
  },
  "communication": {
    "protocol": "stdio",
    "timeout": 60000
  },
  "refreshIntervalCron": "*/30 * * * *",
  "capabilities": {}
}
