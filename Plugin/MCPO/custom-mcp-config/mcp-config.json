{
  "mcpServers": {
    "time": {
      "command": "uvx",
      "args": [
        "mcp-server-time"
      ]
    },
    "WebSearch": {
      "command": "bash",
      "args": [
        "-lc",
        "npx -y mcp-remote https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/mcp --header \"Authorization: Bearer ${DASHSCOPE_API_KEY}\""
      ]
    }
  }
}
