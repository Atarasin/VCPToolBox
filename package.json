{
  "name": "vcptoolbox",
  "version": "7.1.2",
  "main": "Server.js",
  "scripts": {
    "test": "node --test test/rag-params/*.test.js",
    "export:agent-gateway-openapi": "node scripts/exportAgentGatewayOpenApi.js",
    "start:mcp-agent-gateway": "node scripts/start-agent-gateway-mcp-server.js",
    "test:rag-params": "node --test test/rag-params/*.test.js",
    "test:agent-gateway-contracts": "node --test test/agent-gateway-contract-publishing.test.js test/agent-gateway-node-client.test.js",
    "test:agent-gateway-mcp-transport": "node --test test/agent-gateway-mcp-transport.test.js",
    "eval:mock:baseline": "node eval/mock-run-eval.js baseline",
    "eval:mock:candidate": "node eval/mock-run-eval.js candidate",
    "eval:real:baseline": "node eval/real-run-eval.js baseline",
    "eval:real:candidate": "node eval/real-run-eval.js candidate",
    "eval:real:baseline:variant": "node eval/real-run-eval.js baseline --variant-config eval/embedding_variant_config.json",
    "eval:real:candidate:variant": "node eval/real-run-eval.js candidate --variant-config eval/embedding_variant_config.json",
    "eval:rag-params": "node eval/score-rag-eval.js eval/rag_param_eval_set.jsonl eval/results/baseline.json eval/reports/rag_eval_baseline.json && node eval/score-rag-eval.js eval/rag_param_eval_set.jsonl eval/results/candidate.json eval/reports/rag_eval_candidate.json",
    "eval:compare": "node eval/compare-rag-eval.js eval/reports/rag_eval_baseline.json eval/reports/rag_eval_candidate.json eval/reports/rag_eval_diff.md",
    "eval:gate": "node eval/gate-rag-eval.js eval/reports/rag_eval_baseline.json eval/reports/rag_eval_candidate.json eval/reports/rag_eval_gate.json",
    "eval:all": "npm run eval:mock:baseline && npm run eval:mock:candidate && npm run eval:rag-params && npm run eval:compare && npm run eval:gate",
    "eval:all:real": "npm run eval:real:baseline && npm run eval:real:candidate && npm run eval:rag-params && npm run eval:compare && npm run eval:gate",
    "eval:all:real:variant": "npm run eval:real:baseline:variant && npm run eval:real:candidate:variant && npm run eval:rag-params && npm run eval:compare && npm run eval:gate",
    "start": "node server.js",
    "start:admin": "node adminServer.js",
    "start:all": "node server.js & node adminServer.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@dqbd/tiktoken": "^1.0.22",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@mozilla/readability": "^0.6.0",
    "@node-rs/jieba": "^2.0.1",
    "@tavily/core": "^0.5.2",
    "axios": "^1.6.0",
    "basic-auth": "^2.0.1",
    "better-sqlite3": "^12.4.1",
    "chalk": "^5.6.2",
    "cheerio": "^1.1.2",
    "chinese-lunar-calendar": "^1.0.1",
    "chokidar": "^3.5.3",
    "commander": "^14.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "eslint": "^9.39.1",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "flatted": "^3.3.3",
    "hnswlib-node": "^1.4.2",
    "https-browserify": "^1.0.0",
    "https-proxy-agent": "^7.0.4",
    "ioredis": "^5.6.1",
    "jsdom": "^24.1.3",
    "mailparser": "^3.7.4",
    "mammoth": "^1.11.0",
    "md5": "^2.3.0",
    "mime-types": "^3.0.1",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "node-imap": "^0.9.6",
    "node-schedule": "^2.1.1",
    "pdf-parse": "1.1.1",
    "pm2": "^6.0.11",
    "proper-lockfile": "^4.1.2",
    "puppeteer": "^22.15.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-anonymize-ua": "^2.4.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "rss-parser": "^3.13.0",
    "serpapi": "^2.2.1",
    "stylelint": "^16.25.0",
    "trash": "^10.0.0",
    "turndown": "^7.2.1",
    "undici": "^7.13.0",
    "user-agents": "^1.1.597",
    "uuid": "^9.0.0",
    "winston": "^3.17.0",
    "ws": "^8.17.0"
  },
  "overrides": {
    "pdfjs-dist": "2.16.105"
  }
}
